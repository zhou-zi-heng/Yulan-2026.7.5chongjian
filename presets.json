{
  "version": 2,
  "groups": ["运营", "生文", "通用"],
  "presets": [
    {
      "id": "p001",
      "name": "悬疑短篇流程（示例）",
      "group": "运营",
      "steps": [
        {
          "id": "s1",
          "name": "生成悬疑大纲",
          "order": 1,
          "autoChain": false,
          "segments": [
            { "type": "prompt", "hidden": "__PLAIN__你是资深悬疑小说编辑。请根据以下故事种子，生成3个不同方向的悬疑故事大纲。\n\n故事种子：" },
            { "type": "input", "placeholder": "填写故事种子（核心创意）..." },
            { "type": "prompt", "hidden": "__PLAIN__\n\n要求人物设定参考：" },
            { "type": "input", "placeholder": "填写主要人物设定..." },
            { "type": "prompt", "hidden": "__PLAIN__\n\n每个大纲都要包含：核心悬念、关键转折、结局方向。" }
          ]
        },
        {
          "id": "s2",
          "name": "扩写成稿",
          "order": 2,
          "autoChain": false,
          "segments": [
            { "type": "prompt", "hidden": "__PLAIN__你是资深悬疑小说作者。请根据以下大纲扩写成2000字短篇。\n\n大纲：" },
            { "type": "input", "placeholder": "粘贴你筛选好的大纲..." }
          ]
        }
      ]
    }
  ]
}
