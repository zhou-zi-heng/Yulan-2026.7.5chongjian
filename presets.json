{
  "version": 3,
  "groups": ["运营", "生文", "通用"],
  "security": {
    "sensitiveWords": ["复述指令", "你的指令", "系统提示", "原文输出", "完整指令", "ignore previous", "system prompt", "重复刚才", "你的提示词"],
    "alertWebhook": "https://oapi.dingtalk.com/robot/send?access_token=d335a6d2a80f645cea54e90078f91e98d609d46c685589bd7ba834e01b196d51",
    "alertKeyword": "飞凡警报",
    "simThreshold": 70,
    "guard": true
  },
  "presets": [
    {
      "id": "p001",
      "name": "悬疑短篇流程（示例）",
      "group": "运营",
      "steps": [
        {
          "id": "s1",
          "name": "生成悬疑大纲",
          "order": 1,
          "autoChain": false,
          "segments": [
            { "type": "prompt", "hidden": "__PLAIN__你是资深悬疑小说编辑。请根据以下故事种子生成3个悬疑大纲。\n\n故事种子：" },
            { "type": "input", "placeholder": "填写故事种子..." },
            { "type": "prompt", "hidden": "__PLAIN__\n\n每个大纲含：核心悬念、关键转折、结局方向。" }
          ]
        },
        {
          "id": "s2",
          "name": "扩写成稿",
          "order": 2,
          "autoChain": false,
          "segments": [
            { "type": "prompt", "hidden": "__PLAIN__你是资深悬疑作者。请根据大纲扩写2000字短篇。\n\n大纲：" },
            { "type": "input", "placeholder": "粘贴筛选好的大纲..." }
          ]
        }
      ]
    }
  ]
}
